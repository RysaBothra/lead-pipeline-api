# Copy to .env and fill in real values. NEVER commit .env.
# docker-compose reads this via env_file; on a PaaS, set these as env vars.

# ---- API auth (clients must send: Authorization: Bearer <API_TOKEN>) ----
API_TOKEN=generate-a-long-random-secret

# ---- Hasura (keys DB + all pipeline storage) ----
HASURA_GRAPHQL_URL=https://your-app.hasura.app/v1/graphql
HASURA_ADMIN_SECRET=your-hasura-admin-secret

# ---- Enrichment APIs ----
OCEAN_API_KEY=
PROSPEO_API_KEY=
EAZYREACH_CLIENT_ID=
EAZYREACH_CLIENT_SECRET=

# ---- Pipeline tuning (optional) ----
DECISION_TITLES=Founder,CEO,Director
PER_COMPANY_LIMIT=3
FROM_USERNAME=joy
FROM_NAME=Joy

# ---- Server tuning (optional) ----
WEB_CONCURRENCY=2
# PORT=8000   # most PaaS set this for you

# Brevo API keys are NOT here — they live in the Hasura brevo_keys table.
